# Vite only exposes vars prefixed VITE_ to client code -- nothing secret
# belongs here. The Supabase anon key is designed to be public; the JWT
# itself is never persisted to disk (see src/lib/supabase.ts).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_BASE_URL=http://127.0.0.1:8000
