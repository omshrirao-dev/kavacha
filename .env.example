# --- App ---
APP_ENV=development
APP_NAME=kavacha
LOG_LEVEL=INFO

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Postgres (Supabase "Session pooler" connection string) ---
# DATABASE_URL: postgres role, migrations only.
# APP_DATABASE_URL: least-privilege runtime role (Security Addendum Rule 4), used by the app pool.
# Must use the pooler host (aws-0-<region>.pooler.supabase.com, username
# <role>.<project-ref>) -- NOT the direct db.<project-ref>.supabase.co host.
# The direct host resolves IPv6-only on current Supabase infra; platforms
# without IPv6 egress (confirmed on Railway) get "Network is unreachable".
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
APP_DATABASE_URL=postgresql://kavacha_app.your-project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# --- Anthropic (used by langchain-anthropic / LangGraph agents) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- LLM provider switch ---
# TEMP: gemini/groq for dev. Switch to claude before deploy.
# LLM_PROVIDER=claude is the production default; "gemini" or "groq" are
# temporary dev/test detours (see app/core/llm_provider.py).
LLM_PROVIDER=claude
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data

# --- Agent system prompts (see app/core/prompts.py, LICENSE) ---
# This repo's actual prompt text is intentionally not committed. Create
# ./prompts/{architect,ceo_review,monitor_track_a,fix_engine}.txt yourself --
# each one is the system prompt for that agent -- to run this locally.
PROMPT_DIR=./prompts

# --- Notifications ---
# NOTIFICATION_PROVIDER=log is the safe default (writes to server log, never
# fails). Set to "sendgrid" only once SENDGRID_API_KEY is real AND
# NOTIFICATION_FROM_EMAIL is a sender you've actually verified in SendGrid --
# sending from an unverified address fails outright.
NOTIFICATION_PROVIDER=log
SENDGRID_API_KEY=your-sendgrid-api-key
NOTIFICATION_FROM_EMAIL=alerts@yourdomain.com

# --- Security (Wave 1/2 stubs -- unset means "log only" / "no-op", never blocks anyone) ---
# ADMIN_ALERT_EMAIL: where honeypot hits (app/api/v1/honeypot.py) get emailed. Unset = logged only.
ADMIN_ALERT_EMAIL=security@yourdomain.com
# HCAPTCHA_SECRET_KEY: from the hCaptcha dashboard. Unset = app/core/captcha.py always passes;
# login lockout tiers (app/core/login_security.py) still apply on their own either way.
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key
